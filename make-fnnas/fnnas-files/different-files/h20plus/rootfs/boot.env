bootcmd_bootimg_diag=if test -z "${devtype}"; then setenv devtype mmc; fi; if test -z "${devnum}"; then setenv devnum 1; fi; if test -z "${bootpart}"; then setenv bootpart 2; fi; echo [fnnas] boot.env imported; echo [fnnas] scriptaddr=${scriptaddr}; echo [fnnas] part list mmc ${devnum} follows; part list mmc ${devnum}; if test -e ${devtype} ${devnum}:${bootpart} /boot.scr; then echo [fnnas] found ${devtype} ${devnum}:${bootpart} /boot.scr; else echo [fnnas] missing ${devtype} ${devnum}:${bootpart} /boot.scr; fi; if test -e ${devtype} ${devnum}:${bootpart} /armbianEnv.txt; then echo [fnnas] found ${devtype} ${devnum}:${bootpart} /armbianEnv.txt; else echo [fnnas] missing ${devtype} ${devnum}:${bootpart} /armbianEnv.txt; fi
bootcmd_bootimg=run bootcmd_bootimg_diag; if load ${devtype} ${devnum}:${bootpart} ${scriptaddr} /boot.scr; then echo [fnnas] loaded ${devtype} ${devnum}:${bootpart} /boot.scr size=${filesize}; source ${scriptaddr}; else echo [fnnas] Failed to load /boot.scr from ${devtype} ${devnum}:${bootpart}; fi
