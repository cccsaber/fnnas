bootcmd_bootimg_diag=echo [fnnas] boot.env imported; echo [fnnas] scriptaddr=${scriptaddr}; echo [fnnas] part list mmc 0 follows; part list mmc 0; if test -e mmc 0:1 /boot.scr; then echo [fnnas] found mmc 0:1 /boot.scr; else echo [fnnas] missing mmc 0:1 /boot.scr; fi; if test -e mmc 0:1 /armbianEnv.txt; then echo [fnnas] found mmc 0:1 /armbianEnv.txt; else echo [fnnas] missing mmc 0:1 /armbianEnv.txt; fi; if test -e mmc 0:2 /boot.env; then echo [fnnas] found mmc 0:2 /boot.env; else echo [fnnas] missing mmc 0:2 /boot.env; fi
bootcmd_bootimg=run bootcmd_bootimg_diag; if load mmc 0:1 ${scriptaddr} /boot.scr; then echo [fnnas] loaded mmc 0:1 /boot.scr size=${filesize}; source ${scriptaddr}; else echo [fnnas] Failed to load /boot.scr from mmc 0:1; fi
